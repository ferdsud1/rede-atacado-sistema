{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/encartes(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/categorias(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/empresa(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/sorteios(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/contato(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/health",
      "dest": "/api/index.ts"
    },
    {
      "src": "/debug(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|svg|ico|webp|gif|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
